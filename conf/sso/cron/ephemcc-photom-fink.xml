<?xml version="1.0" encoding="UTF-8"?>
<eprocSchema xmlns="file:/usr/local/src/eproc-4.4/XMLSchema/eproc4-v2.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="file:/usr/local/src/eproc-4.4/XMLSchema/eproc4-v2.xsd file:/usr/local/src/eproc-4.4/XMLSchema/eproc4-v2.xsd">

    <comment>Eproc ephemerides</comment>

    <info>
        <user>eproc</user>
        <email>vossp.lte@obspm.fr</email>
        <reference>eprocPhotomOutputs</reference>
    </info>
    <output>
        <param id="1">
            <name>date</name>
            <class>date</class>
            <label>Date</label>
            <format>jd</format>
            <precision>6</precision>
        </param>
        <param id="2">
            <name>iau_code</name>
            <class>text</class>
            <label>IAU_code</label>
            <format>A3</format>
        </param>
        <param id="3">
            <name>lighttime</name>
            <class>scalar</class>
            <label>LightTime</label>
            <unit>day</unit>
            <format>realES</format>
            <width>12</width>
            <precision>6</precision>
        </param>
        <param id="4">
            <name>phase</name>
            <class>angle</class>
            <label>Phase</label>
            <unit>deg</unit>
            <format>dec</format>
            <precision>7</precision>
        </param>
        <param id="5">
            <name>Elong</name>
            <class>angle</class>
            <label>Elong</label>
            <unit>deg</unit>
            <format>dec</format>
            <precision>7</precision>
        </param>
        <param id="6">
            <name>RA</name>
            <class>angle</class>
            <label>RA</label>
            <unit>deg</unit>
            <format>dec</format>
            <precision>7</precision>
        </param>
        <param id="7">
            <name>DEC</name>
            <class>angle</class>
            <label>DEC</label>
            <unit>sdeg</unit>
            <format>dec</format>
            <precision>7</precision>
        </param>
        <param id="8">
            <name>dobs</name>
            <class>scalar</class>
            <label>Dobs</label>
            <unit>au</unit>
            <format>real</format>
            <width>14</width>
            <precision>9</precision>
        </param>
        <param id="9">
            <name>RA_h</name>
            <class>angle</class>
            <label>RA_h</label>
            <unit>deg</unit>
            <format>dec</format>
            <precision>7</precision>
        </param>
        <param id="10">
            <name>DEC_h</name>
            <class>angle</class>
            <label>DEC_h</label>
            <unit>sdeg</unit>
            <format>dec</format>
            <precision>7</precision>
        </param>
        <param id="11">
            <name>dhelio</name>
            <class>scalar</class>
            <label>Dhelio</label>
            <unit>au</unit>
            <format>real</format>
            <width>14</width>
            <precision>9</precision>
        </param>
        <param id="12">
            <name>px_ec</name>
            <class>scalar</class>
            <label>px_ec</label>
            <unit>au</unit>
            <format>real</format>
            <width>17</width>
            <precision>13</precision>
        </param>
        <param id="13">
            <name>py_ec</name>
            <class>scalar</class>
            <label>py_ec</label>
            <unit>au</unit>
            <format>real</format>
            <width>17</width>
            <precision>13</precision>
        </param>
        <param id="14">
            <name>pz_ec</name>
            <class>scalar</class>
            <label>pz_ec</label>
            <unit>au</unit>
            <format>real</format>
            <width>17</width>
            <precision>13</precision>
        </param>
        <param id="15">
            <name>px_h_ec</name>
            <class>scalar</class>
            <label>px_h_ec</label>
            <unit>au</unit>
            <format>real</format>
            <width>17</width>
            <precision>13</precision>
        </param>
        <param id="16">
            <name>py_h_ec</name>
            <class>scalar</class>
            <label>py_h_ec</label>
            <unit>au</unit>
            <format>real</format>
            <width>17</width>
            <precision>13</precision>
        </param>
        <param id="17">
            <name>pz_h_ec</name>
            <class>scalar</class>
            <label>pz_h_ec</label>
            <unit>au</unit>
            <format>real</format>
            <width>17</width>
            <precision>13</precision>
        </param>
	<param id="18">
            <name>vmag</name>
            <class>scalar</class>
            <label>VMag</label>
            <unit>mag</unit>
            <format>real</format>
            <width>7</width>
            <precision>2</precision>
        </param>
</output>

</eprocSchema>
